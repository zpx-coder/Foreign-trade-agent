# ── 应用 ──
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── 数据库 ──
DATABASE_URL=postgresql+asyncpg://ft_user:ft_dev_password@localhost:5432/foreign_trade

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Elasticsearch ──
ELASTICSEARCH_URL=http://localhost:9200

# ── JWT 认证 ──
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI 模型 (DeepSeek) ──
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_TIMEOUT=60

# ── Gmail OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/email-auth/gmail/callback

# ── 邮件发送 ──
EMAIL_SEND_INTERVAL_SECONDS=45
EMAIL_DAILY_QUOTA=450
